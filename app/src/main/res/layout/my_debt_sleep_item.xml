<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#F8FAFC"
    app:cardCornerRadius="12dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/textDebtDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sen, 21 Apr"
            android:textColor="#111827"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDebtEmployeeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="-"
            android:textColor="#111827"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDebtEmployeeNik"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="NIK: -"
            android:textColor="#6B7280"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/textDebtSleep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tidur: 6 jam"
            android:textColor="#475569"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textDebtValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Hutang: 1 jam"
            android:textColor="#B91C1C"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
