<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFFAFD"
    tools:context=".activities.WelcomeActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top|center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:background="@android:color/transparent"
                android:scaleType="fitStart"
                android:src="@drawable/bg_welcome" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_20sdp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:text="Hello Safety Hero"
                android:textColor="#000"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginHorizontal="@dimen/_20sdp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_12sdp"
                android:textAlignment="center"
                android:text="Pantau dan kelola jam tidur dengan mudah untuk memastikan keseimbangan antara produktivitas dan kesehatan. Bersama Savera, tingkatkan kualitas tidur dan performa kerja Anda."
                android:textColor="#000"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginHorizontal="@dimen/_20sdp"
                tools:ignore="HardcodedText" />

            <Button
                android:id="@+id/btnStart"
                android:layout_width="@dimen/_170sdp"
                android:layout_height="wrap_content"
                android:padding="@dimen/_5sdp"
                android:text="Mari Mulai !"
                android:textSize="@dimen/_14sdp"
                android:backgroundTint="@drawable/bg_button"
                android:layout_marginTop="@dimen/_20sdp" />

            <TextView
                android:id="@+id/textVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_10sdp"
                android:textAlignment="center"
                android:text="Versi 2.0.0"
                android:textColor="#000"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_50sdp"
                tools:ignore="HardcodedText" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>